# ============================================================================
# Eve — Environment Configuration
# Copy to .env and fill in the values for your environment.
# ============================================================================

# --- Application ----------------------------------------------------------
EVE_ENV=development                       # development | staging | production
EVE_LOG_LEVEL=INFO
EVE_PORT=8000

# --- Supabase --------------------------------------------------------------
# Eve nutzt den offiziellen supabase-py Client. Es reichen URL + Key.
# Beide findest du im Dashboard:
#   https://supabase.com/dashboard → Project → Settings → API
#
# Project-URL (Cloud) oder Self-Host-URL:
SUPABASE_URL=https://[PROJECT-REF].supabase.co

# Server-Side Admin-Key. Funktioniert mit BEIDEN Formaten parallel:
#   - Alt (JWT):  service_role  → eyJhbGc...
#   - Neu (2025): Secret key    → sb_secret_xxxxxxx
SUPABASE_SERVICE_KEY=

# Storage-Bucket für Creatives + hochgeladene Media-Files (default: eve-media)
SUPABASE_STORAGE_BUCKET=eve-media

# --- LLM Providers --------------------------------------------------------
# Default provider used by the Eve agent: anthropic | openai | openrouter
EVE_LLM_DEFAULT_PROVIDER=anthropic
EVE_LLM_DEFAULT_MODEL=claude-opus-4-7

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=
# When using OpenRouter, you can pin the underlying provider per call;
# this is the fallback list. See https://openrouter.ai/docs/provider-routing
OPENROUTER_DEFAULT_PROVIDERS=Anthropic,OpenAI

# --- Image Generation (fal.ai) -------------------------------------------
FAL_API_KEY=
FAL_IMAGE_MODEL=fal-ai/bytedance/seedream/v4.5/edit

# Reference-Bilder für konsistente Identität (Face/Stil-Anker) lädst du
# einfach in den Supabase-Storage hoch:
#   Bucket  → eve-media  (siehe SUPABASE_STORAGE_BUCKET)
#   Folder  → references/
#   Files   → portrait_1.jpg, portrait_2.png, ...   (4-8 Bilder)
# Eve listet sie zur Laufzeit und übergibt die Public-URLs an fal.ai.
# Pfad nur ändern, wenn dir der Name "references" nicht passt.
FAL_REFERENCES_PATH=references

# --- Messaging: Telegram --------------------------------------------------
TELEGRAM_BOT_TOKEN=
# Set this to your public Webhook URL (e.g. via ngrok / Coolify / production):
TELEGRAM_WEBHOOK_URL=
# Secret used to verify incoming webhooks (optional but recommended)
TELEGRAM_WEBHOOK_SECRET=

# --- Messaging: Slack (optional, Phase 2) --------------------------------
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# --- LinkedIn -------------------------------------------------------------
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=                      # e.g. urn:li:person:abc123

# --- Scheduler ------------------------------------------------------------
# Daily time when the publish-scheduled-posts job runs (UTC)
EVE_DAILY_POST_HOUR_UTC=7

# --- Encryption -----------------------------------------------------------
# Master-Key (Fernet, 32-byte url-safe base64) zum Verschlüsseln von
# OAuth-Tokens. Sicher aufbewahren — wenn der Key verloren geht, sind die
# Tokens in der DB unleserlich (User muss neu autorisieren).
# Generiere mit:
#   uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
EVE_MASTER_KEY=
